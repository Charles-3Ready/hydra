{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hydra",
  "version": "1.1.0",
  "identifier": "com.threereadylab.hydra",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hydra - Many Heads. One Command.",
        "width": 920,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "3Ready Prototyping Lab",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "startMenuFolder": "3ReadyLab"
      }
    }
  }
}
